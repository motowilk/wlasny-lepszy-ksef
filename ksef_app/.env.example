APP_NAME=KSeF ERP App
APP_ENV=dev           # dev | staging | production
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false        # set to false in production
BASE_URL=http://127.0.0.1:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ksef_erp
DB_USER=ksef_user
DB_PASSWORD=change_me

BASIC_AUTH_REALM=KSeF ERP
# REQUIRED: generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_super_secret_key
KSEF_MODE=mock

# Port 25  → plain SMTP (no TLS)
# Port 587 → STARTTLS (most common relay/cloud)
# Port 465 → implicit TLS (SMTPS)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change_me
SMTP_FROM=noreply@ksef.local
DEFAULT_NOTIFICATION_EMAIL=accountant@example.com

LOG_LEVEL=INFO
LOG_DIR=logs

ADMIN_DEFAULT_PASSWORD=change_me_admin_password

# KSeF real API (only needed when KSEF_MODE=live)
KSEF_API_URL=https://api.ksef.mf.gov.pl/v2
KSEF_TOKEN=change_me_ksef_token
KSEF_NIP=0000000000
