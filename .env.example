APP_ENV=staging
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=True
BASE_URL=http://127.0.0.1:8000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ksef_erp
DB_USER=ksef_user
DB_PASSWORD=change_me   # WYMAGANE: ustaw silne, unikalne hasło — nigdy nie używaj tej wartości w produkcji
ADMIN_DEFAULT_PASSWORD=<haslo_dla_uzytkownika_admin>

BASIC_AUTH_REALM=KSeF ERP
SECRET_KEY=<wygenerowany_losowy_klucz>

KSEF_MODE=mock
KSEF_API_URL=https://api-test.ksef.mf.gov.pl/v2
KSEF_NIP=<nip twojej firmy>
KSEF_TOKEN=<token wygenerowany skryptem generate_ksef_token.py>

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ksef.local
DEFAULT_NOTIFICATION_EMAIL=accountant@example.com

LOG_LEVEL=INFO
LOG_DIR=logs

# Worker tuning (opcjonalne)
SCHEDULER_INTERVAL=10800     # interwał schedulera APScheduler (sekundy)
SCHEDULER_STALE_SECONDS=10  # po ilu sekundach bez heartbeatu toast przechodzi na czerwony

# opcjonalnie
DISCORD_WEBHOOK_URL=<tutaj wrzuć swojego webhooka z discorda, jeśli chcesz otrzymywać powiadomienia>

# optional GitHub integration settings
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_PROJECT_ORG=CIRFMF        # default
GITHUB_PROJECT_NUMBER=4           # default